---
import Base from '../../layouts/Base.astro';
import { games } from '../../data/games';
export function getStaticPaths(){return games.map(game=>({params:{slug:game.slug},props:{game}}));}
const { game } = Astro.props;
const platform = Astro.url.pathname.includes('rog-ally') ? 'ROG Ally' : 'Steam Deck';
const fps = platform === 'ROG Ally' ? game.allyFps : game.deckFps;
---
<Base title={`${game.title} ${platform} settings — Handheld Settings Lab`} description={`Recommended baseline ${platform} settings for ${game.title}: ${fps}, storage notes, battery tips, and tuning guidance.`}>
<article class="wrap article"><span class="eyebrow">{platform} baseline</span><h1>{game.title} {platform} settings</h1><p class="lede muted">A practical starting point for {game.title} on {platform}. These are baseline tuning notes; we update pages as patch notes, public specs, and community performance reports change.</p><div class="grid cols3"><div class="card"><h3>Target</h3><div class="stat">{fps}</div></div><div class="card"><h3>Preset</h3><p>{game.preset}</p></div><div class="card"><h3>Install size</h3><div class="stat">{game.storage}GB</div></div></div><h2>Recommended baseline</h2><p>{game.notes}</p><ul><li>Start with the in-game low/medium preset, then raise textures if VRAM allows.</li><li>Use a frame cap before lowering resolution; stable frame pacing usually feels better than spiky peaks.</li><li>For travel, target 30-40 FPS and reduce screen brightness before making the game ugly.</li></ul><div class="callout"><strong>Lab note:</strong> We do not invent benchmark numbers. Pages are marked as baseline recommendations until direct test notes are added.</div><h2>Useful tools</h2><p><a class="btn" href="/calculators/storage-planner/">Check storage</a> <a class="btn ghost" href="/calculators/battery-estimator/">Estimate battery</a></p></article>
</Base>
