---
import Base from '../../layouts/Base.astro';

const sourceLinks = [
  { label: 'Valve Steam Deck technical specifications', url: 'https://www.steamdeck.com/en/tech' },
  { label: 'ASUS ROG Ally X specifications', url: 'https://rog.asus.com/gaming-handhelds/rog-ally/rog-ally-x-2024/spec/' },
  { label: 'Lenovo Legion Go PSREF specifications', url: 'https://psref.lenovo.com/Product/Legion/Legion_Go_8APU1' },
