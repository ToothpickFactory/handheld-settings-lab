];

const chargerTiers = [
  {
    watts: '45W USB-C PD',
    verdict: 'Steam Deck floor',
    detail: 'Good as a Deck-focused spare charger, especially if you only need the handheld and no dock or laptop sharing.'
  },
  {
    watts: '65W USB-C PD',
    verdict: 'Best default',
    detail: 'The safest first wall-charger target for mixed Steam Deck, ROG Ally, Ally X, Legion Go, phone, and travel use.'
  },
  {
    watts: '100W+ USB-C PD',
    verdict: 'Desk/travel hub pick',
