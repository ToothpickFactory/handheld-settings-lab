---
import Base from '../../layouts/Base.astro';

const sourceLinks = [
  { label: 'USB-IF USB Charger / USB Power Delivery overview', url: 'https://www.usb.org/usb-charger-pd' },
  { label: 'Valve Steam Deck technical specifications', url: 'https://www.steamdeck.com/en/tech' },
  { label: 'ASUS ROG Ally X specifications', url: 'https://rog.asus.com/gaming-handhelds/rog-ally/rog-ally-x-2024/spec/' },
  { label: 'Lenovo Legion Go PSREF specifications', url: 'https://psref.lenovo.com/Product/Legion/Legion_Go_8APU1' }
];

const searchLinks = [
  { label: '100W USB-C to USB-C cable', href: 'https://www.amazon.com/s?k=100w+usb+c+to+usb+c+cable' },
  { label: '240W USB-C EPR cable', href: 'https://www.amazon.com/s?k=240w+usb+c+epr+cable' },
  { label: 'Short USB-C PD cable for travel charger', href: 'https://www.amazon.com/s?k=short+usb+c+pd+cable+100w' },
  { label: 'Right angle USB-C cable for handheld gaming', href: 'https://www.amazon.com/s?k=right+angle+usb+c+cable+100w+handheld+gaming' }
