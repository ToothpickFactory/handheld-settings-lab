---
import Base from '../layouts/Base.astro';
import { games, gearPicks } from '../data/games';
---
<Base title="Handheld Settings Lab — Steam Deck & handheld PC settings" description="Find baseline settings, official-source game art, calculators, and gear guides for Steam Deck, ROG Ally, Legion Go, and handheld PC gaming.">
<section class="hero"><div class="wrap hero-grid"><div><span class="eyebrow">Portable PC tuning lab</span><h1>Handheld game settings that hold up.</h1><p class="lede">Practical presets, official-source game visuals, calculators, and gear picks for Steam Deck, ROG Ally, Legion Go, and portable PC players.</p><div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:26px"><a class="btn" href="/steam-deck-settings/">Find game settings</a><a class="btn ghost" href="/calculators/battery-estimator/">Try battery calculator</a></div></div><div class="hero-card"><div class="screen"><span class="chip">Live lab card</span><h2 style="font-size:2.2rem;line-height:1;margin:18px 0 8px">Elden Ring</h2><p class="muted">Steam Deck balanced target</p><img src="/assets/games/elden-ring-header.jpg" alt="Official Elden Ring Steam store art" style="width:100%;border-radius:14px;margin:12px 0;border:1px solid rgba(255,255,255,.1)"/><div class="grid" style="margin-top:18px"><div><strong>Frame target</strong><div class="meter"><span style="width:66%"></span></div><p>40 FPS cap</p></div><div><strong>Battery score</strong><div class="meter"><span style="width:74%"></span></div><p>Balanced travel preset</p></div></div></div></div></div></section>
<section class="section"><div class="wrap"><h2>The launch lab</h2><p class="muted">Structured content built for long-tail searches and easy AI maintenance, with stronger rules against fake benchmark claims and generic AI-looking design.</p><div class="grid cols3"><div class="card"><div class="stat">20+</div><h3>Device setting pages</h3><p class="muted">Steam Deck and ROG Ally pages from one reliable data model.</p></div><div class="card"><div class="stat">3</div><h3>Calculators</h3><p class="muted">Storage, battery, and accessory budget tools live at launch.</p></div><div class="card"><div class="stat">Gear</div><h3>Affiliate-ready guides</h3><p class="muted">Accessory pages route buyers toward Amazon/search links while we wait for a tracking tag.</p></div></div></div></section>
<section class="section"><div class="wrap"><h2>Popular settings</h2><div class="grid cols3">{games.slice(0,6).map(game => <a class="card game-card" href={`/steam-deck-settings/${game.slug}/`}><img src={game.image} alt={game.imageAlt} loading="lazy"/><div class="game-card-body"><span class="chip fps40">{game.deckFps}</span><h3>{game.title}</h3><p class="muted">{game.preset}. Battery: {game.battery}.</p><p class="media-credit">Image: {game.imageSource}</p></div></a>)}</div></div></section>
<section class="section"><div class="wrap"><h2>Gear we’ll review</h2><p class="muted">Accessory coverage is built into the site from the start. Links are Amazon search links until an affiliate tracking ID is added.</p><div class="grid cols4">{gearPicks.map(item => <div class="card gear-card"><span class="chip">{item.bestFor}</span><h3>{item.title}</h3><p class="muted">{item.verdict}</p><strong>{item.price}</strong><a class="btn ghost" href={item.amazonUrl} rel="nofollow sponsored" target="_blank">Shop on Amazon</a></div>)}</div></div></section>
<section class="section"><div class="wrap grid cols2"><div class="card"><h2>Calculators that solve real handheld questions</h2><p class="muted">Estimate storage needs, battery life, and accessory budgets before you buy or install.</p><a class="btn" href="/calculators/storage-planner/">Open storage planner</a></div><div class="card" id="newsletter"><h2>Weekly portable playbook</h2><p class="muted">New settings, patch notes, and handheld gaming gear picks.</p><form class="form" data-newsletter><input type="email" name="email_address" placeholder="you@example.com" required><input type="hidden" name="signup_started_at" value={Date.now().toString()}><input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off"><button class="btn" type="submit">Join</button><p data-status class="muted" style="width:100%"></p></form></div></div></section>
</Base>
