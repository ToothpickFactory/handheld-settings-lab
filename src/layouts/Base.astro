---
import '../styles.css';
const { title='Handheld Settings Lab', description='Steam Deck, ROG Ally, and handheld PC settings, calculators, and gaming gear guides.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---
<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>{title}</title><meta name="description" content={description}/><link rel="canonical" href={canonical}/><link rel="icon" type="image/png" href="/favicon-64.png"/><link rel="apple-touch-icon" href="/favicon-192.png"/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:image" content="/assets/og-handheld-settings-lab.svg"/><meta name="twitter:card" content="summary_large_image"/>{ga4Id && <><script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script><script is:inline define:vars={{ ga4Id }}>{`window.dataLayer = window.dataLayer || [];\nfunction gtag(){dataLayer.push(arguments);}\ngtag('js', new Date());\ngtag('config', ga4Id, { send_page_view: true });`}</script></>}</head><body><header class="site-header"><div class="wrap nav"><a class="brand" href="/"><img class="logo" src="/assets/logo-handheld-settings-lab.png" alt="Handheld Settings Lab logo"/><span>Handheld Settings Lab</span></a><nav class="navlinks"><a href="/steam-deck-settings/">Steam Deck</a><a href="/rog-ally-settings/">ROG Ally</a><a href="/calculators/">Calculators</a><a href="/guides/">Guides</a><a class="btn ghost" href="#newsletter">Newsletter</a></nav></div></header><main><slot /></main><footer class="site-footer"><div class="wrap grid cols2"><div class="brand-strip"><img src="/assets/logo-handheld-settings-lab.png" alt=""/><div><strong>Handheld Settings Lab</strong><p>Game settings, calculators, gear guidance, and official-source editorial images for portable PC gaming. We do not use official platform logos; trademarks belong to their owners.</p></div></div><div><a href="/contact/">Contact</a> · <a href="/privacy/">Privacy</a> · <a href="/terms/">Terms</a> · <a href="/llms.txt">llms.txt</a></div></div></footer><script is:inline>(()=>{document.querySelectorAll('[data-newsletter]').forEach(form=>{form.addEventListener('submit',async e=>{e.preventDefault();const status=form.querySelector('[data-status]');status.textContent='Saving...';try{const res=await fetch('/api/newsletter',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(Object.fromEntries(new FormData(form)))});const data=await res.json();status.textContent=res.ok?'You are on the lab list.':(data.error||'Signup failed.');}catch(err){status.textContent='Signup is temporarily unavailable.';}})})})();</script></body></html>
